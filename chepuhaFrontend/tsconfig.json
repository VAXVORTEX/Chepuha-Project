{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ],
    "strict": true,
    "noUncheckedSideEffectImports": false,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "sourceMap": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@api": ["../chepuhaApi/index.ts"],
      "@api/*": ["../chepuhaApi/*"],
      "@supabase/supabase-js": ["node_modules/@supabase/supabase-js"]
    }
  },
  "include": [
    "src",
    "../chepuhaApi"
  ]
}